# =========================================================================
# Inventory & Order Management System - Environment Variables Template
# Copy this file to '.env' and fill in values for local deployment.
# =========================================================================

# --- BACKEND SERVICE CONFIGURATION ---
# Database connection string (PostgreSQL)
# For local Docker Compose, defaults to: postgresql://postgres:postgres@db:5432/inventory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory

# Allowed CORS Origins (comma-separated list, no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# --- FRONTEND SERVICE CONFIGURATION ---
# Vite backend endpoint URL
VITE_API_URL=http://localhost:8000/api
